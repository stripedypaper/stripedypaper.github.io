{
  "name": "trickcal-tier-list",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "format": "prettier --write \"index.html\" \"vite.config.js\" \"README.md\" \"package.json\" \"src/**/*.{js,jsx,css}\" \"backend/src/**/*.mjs\" \"public/config.json\"",
    "format:check": "prettier --check \"index.html\" \"vite.config.js\" \"README.md\" \"package.json\" \"src/**/*.{js,jsx,css}\" \"backend/src/**/*.mjs\" \"public/config.json\"",
    "lint": "npm run format:check"
  },
  "dependencies": {
    "@mantine/core": "^7.17.8",
    "@mantine/hooks": "^7.17.8",
    "@tabler/icons-react": "^3.36.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "prettier": "^3.5.3",
    "vite": "^6.0.7"
  }
}
